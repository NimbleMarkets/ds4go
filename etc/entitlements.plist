<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ds4go loads libds4.dylib (built and released separately by the ds4
	     fork) at runtime via dlopen. Notarization requires the hardened
	     runtime, whose library validation would otherwise block loading a
	     dylib not signed by this Team ID. This entitlement permits it. -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
